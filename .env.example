# VulnMarket Environment Variables
# Copy this file to .env and fill in the values

# Database (Vercel Postgres or PlanetScale)
DATABASE_URL="postgresql://user:password@host:5432/vulnmarket?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/vulnmarket?sslmode=require"

# JWT Secret - INTENTIONALLY WEAK for training purposes
# VULN: This is the weak secret learners can use to forge tokens
JWT_SECRET=WEAK_SECRET

# Vercel Blob Storage
BLOB_READ_WRITE_TOKEN=your_vercel_blob_token_here

# App URL
NEXTAUTH_URL=http://localhost:3000

# Debug mode - VULN: Exposed via /api/debug endpoint
DEBUG=true

# Internal token - VULN: Used in SSRF challenge
INTERNAL_TOKEN=vm_admin_internal_token_xK9pL2mN
